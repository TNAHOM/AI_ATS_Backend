PROJECT_NAME=AI_ATS_Backend
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_ats
SECRET_KEY=change-this-to-a-long-random-secret
GEMINI_API_KEY=your-gemini-api-key
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
MAX_JOB_APPLICANT_RETRIES=3
# Example issuer: https://<your-clerk-subdomain>.clerk.accounts.dev
CLERK_ISSUER=https://<your-clerk-subdomain>.clerk.accounts.dev
# JWKS URL must use the same Clerk domain as CLERK_ISSUER (/.well-known/jwks.json)
CLERK_JWKS_URL=https://<your-clerk-subdomain>.clerk.accounts.dev/.well-known/jwks.json
# Required for production APIs: enforce audience validation to prevent token reuse across services.
# Use your Clerk JWT template audience/API identifier.
CLERK_AUDIENCE=https://api.yourapp.com
CLERK_JWKS_CACHE_TTL_SECONDS=3600
CLERK_JWT_LEEWAY_SECONDS=10
