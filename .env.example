PROJECT_NAME=AI_ATS_Backend
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_ats
SECRET_KEY=change-this-to-a-long-random-secret
GEMINI_API_KEY=your-gemini-api-key
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
MAX_JOB_APPLICANT_RETRIES=3
# Example issuer: https://your-subdomain.clerk.accounts.dev
CLERK_ISSUER=https://your-subdomain.clerk.accounts.dev
# Set JWKS URL to match your issuer (typically: https://your-subdomain.clerk.accounts.dev/.well-known/jwks.json)
CLERK_JWKS_URL=https://your-subdomain.clerk.accounts.dev/.well-known/jwks.json
# Optional: set your Clerk JWT template audience/API identifier; leave blank to disable audience validation
CLERK_AUDIENCE=
CLERK_JWKS_CACHE_TTL_SECONDS=3600
CLERK_JWT_LEEWAY_SECONDS=10
